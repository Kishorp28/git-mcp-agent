# =============================================================================
# GitHub AI Engineer — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- LLM Provider ---
# Options: openai | anthropic
LLM_PROVIDER=openai

# OpenAI (or any OpenAI-compatible API: Ollama, LiteLLM, Azure, etc.)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o 

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- GitHub MCP Server ---
# Create a token at: https://github.com/settings/tokens
# Scopes: repo, read:org (adjust based on your needs)
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat_here
GITHUB_MCP_ENABLED=true
# GitHub MCP runs via Docker (recommended). Set false to use remote HTTP server.
GITHUB_MCP_USE_DOCKER=true

# --- Filesystem MCP Server ---
FILESYSTEM_MCP_ENABLED=true
# Absolute path the filesystem server may read/write
FILESYSTEM_ALLOWED_PATH=.

# --- Git MCP Server ---
GIT_MCP_ENABLED=true
GIT_REPOSITORY_PATH=.

# --- Application ---
DEBUG=false
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
